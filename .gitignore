# Build output (regenerated by `make`)
myos/build/*
myos/tools/__pycache__/

# Object / binary / image artifacts
*.o
*.obj
*.elf
*.EFI
*.img
*.fd
*.log
*.dump
*.map
*.bin

# OS cruft
.DS_Store

# Keep the build directory placeholders
!myos/build/
!myos/build/bootloader/.gitkeep
!myos/build/kernel/.gitkeep
!myos/build/image/.gitkeep
