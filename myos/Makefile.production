# ---- Work Unit F: networking ----------------------------------------------
verify-network: image
	$(call need,$(PY),Install Python 3.)
	$(PY) tools/verify_qemu.py --image $(IMAGE) --test-name network --timeout 120 \
	  --log $(B_IMG)/network.log \
	  --expect "[OK] NIC driver" \
	  --expect "[PASS] Ethernet" \
	  --expect "[PASS] ARP" \
	  --expect "[PASS] IPv4" \
	  --expect "[PASS] ICMP ping" \
	  --expect "[PASS] UDP" \
	  --expect "[PASS] DHCP" \
	  --expect "[PASS] DNS" \
	  --expect "[PASS] socket API" \
	  --expect "[OK] Networking foundation online"

# Per-protocol sub-targets grep the same network serial log for one marker each.
verify-ethernet: image
	$(PY) tools/verify_qemu.py --image $(IMAGE) --test-name net-eth --timeout 120 \
	  --log $(B_IMG)/net-eth.log --expect "[PASS] Ethernet"
verify-arp: image
	$(PY) tools/verify_qemu.py --image $(IMAGE) --test-name net-arp --timeout 120 \
	  --log $(B_IMG)/net-arp.log --expect "[PASS] ARP"
verify-ipv4: image
	$(PY) tools/verify_qemu.py --image $(IMAGE) --test-name net-ip --timeout 120 \
	  --log $(B_IMG)/net-ip.log --expect "[PASS] IPv4"
verify-icmp: image
	$(PY) tools/verify_qemu.py --image $(IMAGE) --test-name net-icmp --timeout 120 \
	  --log $(B_IMG)/net-icmp.log --expect "[PASS] ICMP ping"
verify-udp: image
