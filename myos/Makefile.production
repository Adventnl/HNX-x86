	  --log $(B_IMG)/process-expanded.log \
	  --expect "[PASS] process tree tests" \
	  --expect "[PASS] waitpid tests" \
	  --expect "[PASS] zombie cleanup tests" \
	  --expect "[OK] Process/syscall production foundation online"

verify-syscall-expanded: image
